      { "name": "DST_PFScouting_SingleMuon", "type": "O", "onlyMC": false },
      { "name": "DST_PFScouting_JetHT", "type": "O", "onlyMC": false },
      { "name": "Pileup_nTrueInt", "type": "F", "onlyMC": true },
      { "name": "nScoutingFatPFJetRecluster", "type": "I", "onlyMC": false },
