          { "name": "ScoutingMuonVtx_nValidStandAloneMuonHits", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_nValidPixelHits", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_nTrackerLayersWithMeasurement", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_nStandAloneMuonMatchedStations", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_nRecoMuonMatchedStations", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_nValidRecoMuonHits", "type": "I", "onlyMC": false },
          { "name": "ScoutingMuonVtx_trk_dxy", "type": "F", "onlyMC": false },
          { "name": "ScoutingMuonVtx_trk_dz", "type": "F", "onlyMC": false }
        ]
      },
      {
        "name": "ScoutingFatPFJetRecluster",
        "size": "nScoutingFatPFJetRecluster",
        "max_size": 20,
        "p4": {
          "pt": "ScoutingFatPFJetRecluster_pt",
          "eta": "ScoutingFatPFJetRecluster_eta",
          "phi": "ScoutingFatPFJetRecluster_phi",
          "mass": "ScoutingFatPFJetRecluster_mass",
          "default_mass": 0.0
        },
        "fields": [
          { "name": "ScoutingFatPFJetRecluster_pt", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_eta", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_phi", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_msoftdrop", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_mass", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_scoutGlobalParT_prob_Xud", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_scoutGlobalParT_prob_Xcs", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_scoutGlobalParT_prob_Xqq", "type": "F", "onlyMC": false },
          { "name": "ScoutingFatPFJetRecluster_scoutGlobalParT_prob_Xbb", "type": "F", "onlyMC": false },
