{
  "submit_trees": ["fat2", "fat3"],
  "sample_config": "../../src/sample.json",
  "input_root": "../../dataset",
  "input_pattern": "{input_root}/{sample_group}_mixed/{sample}.root",
  "output_root": "./{tree_name}_v7",
  "model_pattern": "{output_root}/{tree_name}_model",
  "entries_per_sample": 20000000,
  "train_fraction": 0.7,
  "random_state": 42,
  "decor_lambda": 0.02,
  "decor_loss_mode": "smooth_cvm",
  "decor_n_bins": 5,
  "decor_n_thresholds": 31,
  "decor_score_tau": 0.2,
  "decor_bin_tau_scale": 0.25,
  "class_groups": {
    "VVV": ["www", "wwz", "wzz", "zzz"],
    "VH":  ["zh_had", "ggzh_had", "wplush", "wminush"],
    "Top": ["ttbar_had", "ttbar_semilep"],
    "VT": ["tbarwplus_had", "twminus_had"],
    "VV":  ["ww", "wz", "zz"],
    "QCD_HTLOW": ["qcd_ht100to200", "qcd_ht200to400", "qcd_ht400to600", "qcd_ht600to800"],
    "QCD_HTMID": ["qcd_ht800to1000", "qcd_ht1000to1200"],
    "QCD_HTHIGH": ["qcd_ht1200to1500", "qcd_ht1500to2000", "qcd_ht2000"]
  },
  "fat2": {
    "n_estimators": 4000,
    "n_estimators_decorr": 2000,
    "max_depth": 10,
    "gamma": 5,
    "learning_rate": 0.01,
    "learning_rate_decorr": 0.1,
    "min_learning_rate": 0.0005,
    "lr_reduce_patience": 4,
    "reg_lambda": 5,
    "reg_alpha": 5,
    "min_child_weight": 5,
    "subsample": 1.0,
    "colsample_bytree": 0.8,
    "colsample_bynode": 0.8,
    "early_stopping_rounds": 10,
    "decorrelate": ["ScoutingFatPFJetRecluster_msoftdrop_1", "ScoutingFatPFJetRecluster_msoftdrop_2"],
    "decor_efficiencies": [1.0, 0.5, 0.1, 0.05],
    "event_reweight_branches": ["weight_pu"]
  },
  "fat3": {
    "n_estimators": 3000,
    "n_estimators_decorr": 2000,
    "max_depth": 8,
    "gamma": 5,
    "learning_rate": 0.01,
    "learning_rate_decorr": 0.1,
    "min_learning_rate": 0.0005,
    "lr_reduce_patience": 4,
    "reg_lambda": 6,
    "reg_alpha": 6,
    "min_child_weight": 5,
    "subsample": 1.0,
    "colsample_bytree": 0.8,
    "colsample_bynode": 0.8,
    "early_stopping_rounds": 10,
    "decorrelate": ["ScoutingFatPFJetRecluster_msoftdrop_1", "ScoutingFatPFJetRecluster_msoftdrop_2", "ScoutingFatPFJetRecluster_msoftdrop_3"],
    "decor_efficiencies": [1.0, 0.5, 0.1, 0.05],
    "event_reweight_branches": ["weight_pu"]
  }
}
