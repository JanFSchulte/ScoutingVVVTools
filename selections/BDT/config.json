{
  "submit_trees": ["fat3", "fat2"],
  "sample_config": "../../src/sample.json",
  "input_root": "../../dataset",
  "input_pattern": "{input_root}/{sample_group}_mixed/{sample}.root",
  "output_root": "./{tree_name}_UParTv2_v3",
  "model_pattern": "{output_root}/{tree_name}_model",
  "model_type": "bdt",
  "entries_per_sample": 10000000,
  "train_fraction": 0.7,
  "random_state": 42,
  "decor_lambda": 0.005,
  "decor_loss_mode": "smooth_cvm",
  "decor_n_bins": 5,
  "decor_n_thresholds": 31,
  "decor_score_tau": 0.2,
  "decor_bin_tau_scale": 0.25,
  "decor_msoftdrop_training_max": 200,
  "class_groups": {
    "VVV": ["www", "wwz", "wzz", "zzz"],
    "VH":  ["zh_had", "ggzh_had", "wplush", "wminush"],
    "Top": ["ttbar_had", "ttbar_semilep"],
    "VT": ["tbarwplus_had", "twminus_had"],
    "VV":  ["ww", "wz", "zz"],
    "QCD": ["qcd_ht100to200", "qcd_ht200to400", "qcd_ht400to600", 
            "qcd_ht600to800", "qcd_ht800to1000", "qcd_ht1000to1200", 
            "qcd_ht1200to1500", "qcd_ht1500to2000", "qcd_ht2000"]
  },
  "fat2": {
    "n_estimators": 4000,
    "n_estimators_decorr": 2000,
    "max_depth": 9,
    "gamma": 5,
    "learning_rate": 0.05,
    "learning_rate_decorr": 0.2,
    "min_learning_rate": 0.0005,
    "lr_reduce_patience": 4,
    "reg_lambda": 5,
    "reg_alpha": 5,
    "min_child_weight": 5,
    "subsample": 0.8,
    "colsample_bytree": 0.9,
    "colsample_bynode": 0.9,
    "early_stopping_rounds": 30,
    "decorrelate": ["ScoutingFatPFJetRecluster_msoftdrop_1"],
    "decor_efficiencies": [1.0, 0.5, 0.1, 0.05],
    "event_reweight_branches": ["weight_pu"]
  },
  "fat3": {
    "n_estimators": 4000,
    "n_estimators_decorr": 2000,
    "max_depth": 7,
    "gamma": 5,
    "learning_rate": 0.05,
    "learning_rate_decorr": 0.2,
    "min_learning_rate": 0.0005,
    "lr_reduce_patience": 4,
    "reg_lambda": 6,
    "reg_alpha": 6,
    "min_child_weight": 6,
    "subsample": 0.75,
    "colsample_bytree": 0.9,
    "colsample_bynode": 0.9,
    "early_stopping_rounds": 30,
    "decorrelate": ["ScoutingFatPFJetRecluster_msoftdrop_1"],
    "decor_efficiencies": [1.0, 0.5, 0.1, 0.05],
    "event_reweight_branches": ["weight_pu"]
  },
  "fat2_nn": {
    "epochs": 200,
    "epochs_decorr": 100,
    "hidden_layers": [512, 256, 128],
    "activation": "silu",
    "dropout": 0.1,
    "batch_norm": false,
    "batch_size": 200000,
    "learning_rate": 0.001,
    "learning_rate_decorr": 0.0005,
    "min_learning_rate": 0.00002,
    "lr_reduce_patience": 6,
    "weight_decay": 0.0001,
    "early_stopping_rounds": 10,
    "permutation_importance_events": 1000000
  },
  "fat3_nn": {
    "epochs": 180,
    "epochs_decorr": 100,
    "hidden_layers": [384, 256, 128],
    "activation": "silu",
    "dropout": 0.1,
    "batch_norm": false,
    "batch_size": 200000,
    "learning_rate": 0.001,
    "learning_rate_decorr": 0.0005,
    "min_learning_rate": 0.00002,
    "lr_reduce_patience": 6,
    "weight_decay": 0.0001,
    "early_stopping_rounds": 10,
    "permutation_importance_events": 1000000
  }
}
